@model IEnumerable<House_Renting_System.Models.House.HousesViewModel>

<h2 class="text-center">@ViewBag.Title</h2>
<hr />

<div class="text-center row">
    @foreach (var house in Model)
    {
        <div class="card col-4 m-2 p-0" style="width: 20rem;">
            <img class="card-img-top" src="@house.ImageUrl" alt="House Image">

            <div class="card-body">
                <h5 class="card-title">@house.Name</h5>
                <p class="card-text">@house.Address</p>
            </div>

            <div class="card-footer">
                <a asp-controller="House"
                   asp-action="Details"
                   asp-route-id="@house.Id"
                   class="btn btn-info">
                    Details
                </a>

                @if (User.Identity != null && User.Identity.IsAuthenticated && house.CurentUserIsOwner)
                {
                    <a asp-controller="House"
                       asp-action="Edit"
                       asp-route-id="@house.Id"
                       class="btn btn-warning">
                        Edit
                    </a>

                    <a asp-controller="House"
                       asp-action="Delete"
                       asp-route-id="@house.Id"
                       class="btn btn-danger">
                        Delete
                    </a>
                }
            </div>
        </div>
    }
</div>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="mt-4 text-center">
        <a asp-controller="House"
           asp-action="CreateHouse"
           class="btn btn-primary">
            Register House
        </a>
    </div>
}